# Copia este archivo a ".env.local" y completa los valores.
# Las variables VITE_* se hornean en build-time: define los IDs ANTES de
# compilar (npm run build) y desplegar para que tomen efecto.

# Número de WhatsApp (formato wa.me: dígitos, sin "+" ni espacios). Ej. 573001234567
VITE_WHATSAPP_NUMBER=57XXXXXXXXXX

# URL final del sitio (para canonical / Open Graph / schema)
VITE_SITE_URL=https://tu-dominio.com

# Google Tag Manager (única capa de medición). Dentro de GTM se configuran
# GA4, Meta Pixel y Google Ads. Si lo dejas vacío, no se carga nada.
VITE_GTM_ID=GTM-XXXXXXX
